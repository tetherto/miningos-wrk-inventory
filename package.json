{
  "name": "@tetherto/miningos-wrk-inventory",
  "version": "0.0.1",
  "description": "MiningOS Worker Inventory",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/miningos-wrk-inventory.git"
  },
  "homepage": "https://github.com/tetherto/miningos-wrk-inventory#readme",
  "bugs": {
    "url": "https://github.com/tetherto/miningos-wrk-inventory/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "worker.js",
    "workers/"
  ],
  "type": "commonjs",
  "bin": {
    "miningos-wrk-inventory": "worker.js"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "brittle tests/unit/*.js",
    "test:coverage": "brittle --coverage tests/{,**/}*.test.js",
    "dev": "node worker.js --wtype wrk-inventory-rack-miner_part-psu --env development --rack rack-1"
  },
  "dependencies": {
    "@bitfinex/bfx-svc-boot-js": "1.2.0",
    "@tetherto/miningos-lib-stats": "git+https://github.com/tetherto/miningos-lib-stats.git",
    "@tetherto/miningos-tpl-wrk-thing": "git+https://github.com/tetherto/miningos-tpl-wrk-thing.git",
    "async": "3.2.6",
    "hyperblobs": "^2.12.0"
  },
  "devDependencies": {
    "brittle": "3.16.3",
    "standard": "17.1.0"
  }
}
